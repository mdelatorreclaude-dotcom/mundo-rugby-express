{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/cron",  "dest": "/api/cron.js" },
    { "src": "/api/data",  "dest": "/api/data.js" },
    { "src": "/api/claude","dest": "/api/claude.js" },
    { "src": "/(.*)",      "dest": "/public/$1" }
  ],
  "crons": [
    { "path": "/api/cron", "schedule": "0 11 * * 5" },
    { "path": "/api/cron", "schedule": "0 11 * * 6" },
    { "path": "/api/cron", "schedule": "0 14 * * 6" },
    { "path": "/api/cron", "schedule": "0 20 * * 6" },
    { "path": "/api/cron", "schedule": "0 11 * * 0" },
    { "path": "/api/cron", "schedule": "0 15 * * 0" },
    { "path": "/api/cron", "schedule": "0 20 * * 0" },
    { "path": "/api/cron", "schedule": "0 11 * * 1" }
  ]
}
